# Local development environment variables for backend
# Use SQLite by default; uncomment and set Postgres URL for production/dev with Postgres.
DATABASE_URL=sqlite:///./data/dev.db
# Example Postgres URL (uncomment to use):
# DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5432/iba_db

# JWT / auth
SECRET_KEY=change-me-super-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Seed user credentials (used by scripts/seed.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
TEST_EMAIL=user@example.com
TEST_PASSWORD=password123

# Optional services
REDIS_URL=redis://localhost:6379/0
# PINECONE_KEY=your-pinecone-key
# SENTRY_DSN=

# Other env toggles
ENV=development