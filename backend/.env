# Local development environment variables for backend
# Use SQLite by default; uncomment and set Postgres URL for production/dev with Postgres.
DATABASE_URL=sqlite:///./data/dev.db
# Example Postgres URL (uncomment to use):
# DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5432/iba_db

# JWT / auth
SECRET_KEY=change-me-super-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Seed user credentials (used by scripts/seed.py)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
TEST_EMAIL=user@example.com
TEST_PASSWORD=password123

# Optional services
REDIS_URL=redis://localhost:6379/0
# LLM provider keys & config (set real keys in your environment)
OPENROUTER_KEY=          # set your OpenRouter / Gemini API key
OPENROUTER_URL=https://api.openrouter.ai

DEEPSEEK_API_KEY=        # set your DeepSeek API key
DEEPSEEK_URL=https://api.deepseek.ai

# Comma-separated provider preference order (first = highest priority)
# Example: MODEL_PREFERENCES=openrouter,deepseek
MODEL_PREFERENCES=openrouter,deepseek
LLM_DEFAULT_PROVIDER=openrouter

# Rate limiting config (used by backend/middleware/rate_limit.py or similar)
# RATE_LIMIT_REQUESTS: number of requests allowed per window per key (e.g. per IP)
# RATE_LIMIT_WINDOW: window size in seconds (e.g. 60 = 1 minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# PINECONE_KEY=your-pinecone-key
# SENTRY_DSN=

# Vector DB / Chroma settings
# CHROMA_DIR: local persist directory for chroma (duckdb+parquet). Example: ./data/vector_db/chroma
CHROMA_DIR=./data/vector_db/chroma
# CHROMA_API_KEY: use when connecting to a remote Chroma server with API key (leave blank for local)
CHROMA_API_KEY=

# Embedding model default (used by embeddings service)
EMBEDDING_MODEL=deeps-embed-1

# Other env toggles
ENV=development
